rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return isAuthenticated() && userDocExists()
        ? userDoc().data.role
        : null;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isProduction() {
      return hasRole('production');
    }

    function isProcurement() {
      return hasRole('procurement');
    }

    function isStore() {
      return hasRole('store') || hasRole('user');
    }

    function canViewAllSubmissions() {
      return isProduction() || isProcurement() || isAdmin();
    }

    function hasOnlyKeys(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function tableIsOpen() {
      return !(resource.data.request_status == 'DONE' || resource.data.request_closed == true);
    }

    function tableDoc(tableId) {
      return get(/databases/$(database)/documents/tables/$(tableId));
    }

    function tableExists(tableId) {
      return exists(/databases/$(database)/documents/tables/$(tableId));
    }

    function isTableOwner(tableId) {
      return tableExists(tableId) &&
             tableDoc(tableId).data.user_id == request.auth.uid;
    }

    function canReadTable(tableId) {
      return isAuthenticated() && tableExists(tableId) && (
        tableDoc(tableId).data.user_id == request.auth.uid ||
        (canViewAllSubmissions() && tableDoc(tableId).data.submitted == true) ||
        isAdmin()
      );
    }

    function isChatClosed(tableId) {
      return tableDoc(tableId).data.request_status == 'DONE' ||
             tableDoc(tableId).data.request_closed == true;
    }

    function canParticipateInTableChat(tableId) {
      return canReadTable(tableId);
    }

    function poUploadKeys() {
      return [
        'po_file_data', 'po_file_mime', 'po_file_name', 'po_file_size',
        'po_file_type', 'po_file_url', 'po_uploaded_at', 'po_uploaded_by',
        'po_removed_at', 'po_removed_by', 'updated_at'
      ];
    }

    function smUploadKeys() {
      return [
        'sm_file_data', 'sm_file_mime', 'sm_file_name', 'sm_file_size',
        'sm_file_type', 'sm_file_url', 'sm_uploaded_at', 'sm_uploaded_by',
        'sm_removed_at', 'sm_removed_by', 'updated_at'
      ];
    }

    function closeInitKeys() {
      return [
        'close_request_pending', 'close_request_user_accepted', 'close_request_production_accepted',
        'close_request_initiated_at', 'close_request_initiated_by', 'close_request_mode', 'updated_at'
      ];
    }

    function closeRejectKeys() {
      return [
        'close_request_pending', 'close_request_user_accepted',
        'close_request_production_accepted', 'close_request_mode', 'updated_at'
      ];
    }

    function closeFinalizeKeys() {
      return [
        'request_status', 'request_closed', 'request_closed_at', 'request_closed_by',
        'close_request_pending', 'close_request_mode', 'updated_at'
      ];
    }

    function notTransferredToProcurement() {
      return resource.data.get('production_reviewed', false) != true;
    }

    function canInitiateDeliveryRequest() {
      return resource.data.submitted == true &&
             hasOnlyKeys(closeInitKeys()) &&
             request.resource.data.close_request_pending == true;
    }

    function procurementWorkflowTable() {
      return (isProcurement() || isAdmin()) &&
             resource.data.submitted == true &&
             resource.data.production_reviewed == true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() && (
        (request.auth.uid == userId &&
          !exists(/databases/$(database)/documents/users/$(userId))) ||
        (request.auth.uid == userId &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isAdmin()
      );
    }

    match /masterData/{document} {
      allow read: if isAuthenticated();
      allow write: if isStore() || isAdmin();
    }

    match /tables/{tableId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        (canViewAllSubmissions() && resource.data.submitted == true) ||
        isAdmin()
      );

      allow create: if isAuthenticated() && (
        (isStore() &&
          request.resource.data.user_id == request.auth.uid &&
          (request.resource.data.type == 'requisition' || request.resource.data.type == 'production')) ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.submitted != true &&
          request.resource.data.user_id == request.auth.uid) ||
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          request.resource.data.submitted == true) ||
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          tableIsOpen() &&
          hasOnlyKeys(['close_request_user_accepted', 'updated_at'])) ||
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          hasOnlyKeys(closeRejectKeys())) ||
        ((isStore() || isProduction()) &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          hasOnlyKeys(closeFinalizeKeys()) &&
          request.resource.data.request_status == 'DONE' &&
          request.resource.data.request_closed == true) ||
        (isProduction() &&
          resource.data.submitted == true &&
          'production_reviewed' in request.resource.data.diff(resource.data).affectedKeys()) ||
        (isProduction() &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          tableIsOpen() &&
          hasOnlyKeys(['close_request_production_accepted', 'updated_at'])) ||
        (isProduction() &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          hasOnlyKeys(closeRejectKeys())) ||
        // Production: initiate delivery when fulfilling from stock (no procurement transfer)
        (isProduction() &&
          canInitiateDeliveryRequest() &&
          notTransferredToProcurement() &&
          request.resource.data.get('close_request_mode', '') == 'production') ||
        // Production: Shipping Manifest upload/remove
        (isProduction() &&
          resource.data.submitted == true &&
          hasOnlyKeys(smUploadKeys())) ||
        // Procurement/admin: workflow updates (P.O., close request, etc.)
        (procurementWorkflowTable()) ||
        // Procurement/admin: initiate delivery request after transfer (explicit keys, no tableIsOpen gate)
        ((isProcurement() || isAdmin()) &&
          canInitiateDeliveryRequest() &&
          resource.data.get('production_reviewed', false) == true) ||
        // Procurement/admin: reset close request fields
        ((isProcurement() || isAdmin()) &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          hasOnlyKeys(closeRejectKeys())) ||
        // Procurement/admin: finalize close request
        ((isProcurement() || isAdmin()) &&
          resource.data.submitted == true &&
          resource.data.close_request_pending == true &&
          hasOnlyKeys(closeFinalizeKeys()) &&
          request.resource.data.request_status == 'DONE' &&
          request.resource.data.request_closed == true) ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.submitted != true) ||
        isAdmin()
      );

      // Table chat messages (User, Production, Procurement)
      match /messages/{messageId} {
        function parentTableData() {
          return get(/databases/$(database)/documents/tables/$(tableId)).data;
        }

        function canAccessChat() {
          return isAuthenticated() &&
                 exists(/databases/$(database)/documents/tables/$(tableId)) &&
                 (
                   parentTableData().user_id == request.auth.uid ||
                   (canViewAllSubmissions() && parentTableData().submitted == true) ||
                   isAdmin()
                 );
        }

        allow read: if canAccessChat();

        allow create: if canAccessChat() &&
          request.resource.data.sender_id == request.auth.uid &&
          request.resource.data.created_at is string &&
          request.resource.data.message_type is string &&
          (
            (request.resource.data.message_type == 'image' &&
              request.resource.data.image_data is string &&
              request.resource.data.image_mime is string) ||
            (request.resource.data.message_type != 'image' &&
              request.resource.data.message is string)
          );

        allow update, delete: if false;
      }
    }

    match /requisitions/{reqId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        (isProduction() && resource.data.status == 'Submitted') ||
        (isProduction() && resource.data.production_action != null) ||
        (isProcurement() && resource.data.production_action == 'confirmed') ||
        (isProcurement() && resource.data.status in ['Scheduled', 'Delivered', 'Partially_Delivered']) ||
        isAdmin()
      );

      allow create: if isAuthenticated() && (
        (isStore() &&
          request.resource.data.user_id == request.auth.uid &&
          request.resource.data.status == 'Pending' &&
          request.resource.data.table_id != null) ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.status == 'Pending' &&
          request.resource.data.status == 'Pending') ||
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.status == 'Pending' &&
          request.resource.data.status == 'Submitted') ||
        (isProduction() &&
          resource.data.status == 'Submitted' &&
          (request.resource.data.status in ['Production_Confirmed', 'Removed'] ||
           (request.resource.data.status == resource.data.status &&
            hasOnlyKeys([
              'production_action', 'production_action_at', 'production_action_by',
              'production_action_notes', 'production_notes', 'materials', 'updated_at'
            ])))) ||
        (isProcurement() &&
          resource.data.production_action == 'confirmed' &&
          request.resource.data.status == resource.data.status &&
          hasOnlyKeys(['materials', 'updated_at'])) ||
        (isProcurement() &&
          resource.data.production_action == 'confirmed' &&
          request.resource.data.status in ['Scheduled', 'Delivered', 'Partially_Delivered']) ||
        (isProcurement() &&
          resource.data.status == 'Scheduled' &&
          request.resource.data.status in ['Delivered', 'Partially_Delivered']) ||
        (isProcurement() &&
          resource.data.status == 'Partially_Delivered' &&
          request.resource.data.status == 'Delivered') ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        (isStore() &&
          resource.data.user_id == request.auth.uid &&
          resource.data.status == 'Pending') ||
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (
        (isStore() || isProduction() || isProcurement() || isAdmin()) &&
        request.resource.data.userId is string
      );
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAuthenticated() && (
        (isStore() && request.resource.data.user_id == request.auth.uid) ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        (isStore() && resource.data.user_id == request.auth.uid) ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        (isStore() && resource.data.user_id == request.auth.uid) ||
        isAdmin()
      );
    }
  }
}
